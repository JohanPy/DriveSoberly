<?xml version="1.0" encoding="utf-8"?>
<!--
    Data extraction rules (Android 12+, API 31+).
    Covers both cloud backup and device-to-device transfer.
    We exclude SharedPreferences because the EncryptedSharedPreferences encryption key
    lives in the Android Keystore and is NOT transferred; the encrypted data would be
    unreadable on the target device.
    The Room database (drink history) is still included.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" path="USER_PREFS.xml" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="USER_PREFS.xml" />
    </device-transfer>
</data-extraction-rules>
