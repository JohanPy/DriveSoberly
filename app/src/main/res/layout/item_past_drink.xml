<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@drawable/drink_item_background"
    android:orientation="horizontal"
    android:gravity="start"
    android:layout_marginBottom="8dp"
    android:padding="10dp">

    <LinearLayout
        android:id="@+id/linearPastDrinkTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        >

        <TextView
            android:id="@+id/textViewPastDrinkTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_margin="5dp"
            android:text="time"
            android:textColor="?attr/colorOnSurfaceVariant"
            tools:ignore="HardcodedText" />

        <TextView android:id="@+id/textViewPastDays"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="days"
            android:textColor="?attr/colorOnSurfaceVariant"
            tools:ignore="HardcodedText" />

    </LinearLayout>

    <ImageView
        android:id="@+id/imageViewPresetDrinkIcon"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_gravity="center"
        android:background="@drawable/drink_icon_badge"
        android:padding="10dp"
        android:src="@drawable/ic_local_drink_white_24dp"
        android:tint="?attr/colorOnPrimaryContainer"
        android:contentDescription="@string/content_desc_drink_icon"
        app:layout_constraintStart_toEndOf="@+id/linearPastDrinkTime"
        app:layout_constraintTop_toTopOf="parent"
        />

    <TextView
        android:id="@+id/textViewPresetDrinkDescription"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="5dp"
        android:textSize="16sp"
        android:textColor="?attr/colorOnSurface"
        android:text="drink_description"
        tools:ignore="HardcodedText"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toEndOf="@id/imageViewPresetDrinkIcon"
        app:layout_constraintEnd_toStartOf="@id/buttonAddPastDrink"
        />

    <TextView
        android:id="@+id/textViewPresetDrinkProperties"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="5dp"
        android:textSize="12sp"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:text="quantity &amp; rate"
        tools:ignore="HardcodedText"
        app:layout_constraintStart_toEndOf="@id/imageViewPresetDrinkIcon"
        app:layout_constraintTop_toBottomOf="@id/textViewPresetDrinkDescription"
        app:layout_constraintEnd_toStartOf="@id/buttonAddPastDrink"
        />

    <ImageButton
        android:id="@+id/buttonAddPastDrink"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="@drawable/background_round_button_small_primary"
        android:layout_gravity="center"
        android:layout_margin="5dp"
        android:padding="5dp"
        android:src="@drawable/ic_add_white_24dp"
        android:tint="?attr/colorOnPrimary"
        android:contentDescription="@string/content_desc_add_same_drink"
        tools:ignore="HardcodedText"
        app:layout_constraintEnd_toStartOf="@id/buttonRemovePastDrink"
        app:layout_constraintTop_toTopOf="parent"
        />

    <ImageButton
        android:id="@+id/buttonRemovePastDrink"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:background="@drawable/background_round_button_small_primary"
        android:layout_gravity="center"
        android:layout_margin="5dp"
        android:padding="5dp"
        android:src="@drawable/ic_delete_white_24dp"
        android:tint="?attr/colorOnPrimary"
        android:contentDescription="@string/content_desc_delete_drink"
        tools:ignore="HardcodedText"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        />



</androidx.constraintlayout.widget.ConstraintLayout>